# ============================================================
# JobPilot AI - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider (pick one) ---
# Option 1: OpenAI
OPENAI_API_KEY=sk-...

# Option 2: Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Option 3: Groq (free tier available)
GROQ_API_KEY=gsk_...

# Option 4: Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Active LLM Model (LiteLLM format) ---
# OpenAI:    gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Claude:    claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# Groq:      groq/llama3-70b-8192 | groq/mixtral-8x7b-32768
# Ollama:    ollama/llama3.1 | ollama/mistral
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./jobpilot.db

# --- ChromaDB (vector store) ---
CHROMA_PERSIST_PATH=./chroma_db

# --- Application ---
APP_NAME=JobPilot AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# --- Job Search Settings ---
DEFAULT_JOB_PORTALS=linkedin,indeed,naukri
MAX_JOBS_PER_SEARCH=50
JOB_MATCH_THRESHOLD=0.65          # Min cosine similarity score (0-1)

# --- Outreach Settings ---
OUTREACH_REVIEW_REQUIRED=true     # Always require human review before sending
MAX_DAILY_OUTREACH=20             # Safety limit

# --- Browser Settings ---
BROWSER_HEADLESS=false            # Set true to hide browser window
BROWSER_SLOW_MO=50                # Slow down actions (ms) for visibility
PLAYWRIGHT_TIMEOUT=30000          # Action timeout in ms
